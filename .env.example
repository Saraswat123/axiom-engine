# Copy to .env and fill in values
# cp .env.example .env

# Required for Claude (anthropic provider)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — model provider (default: anthropic)
# Options: anthropic | ollama | openai | huggingface
AXIOM_PROVIDER=anthropic
AXIOM_MODEL=claude-sonnet-4-6

# Ollama (local, no API key needed)
# AXIOM_PROVIDER=ollama
# AXIOM_MODEL=llama3.2
# OLLAMA_URL=http://host.docker.internal:11434

# OpenAI fallback
# AXIOM_PROVIDER=openai
# AXIOM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# Logging
RUST_LOG=axiom=info,tower_http=info
